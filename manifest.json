{
  "manifest_version": 3,
  "name": "LinkedIn Profile Scraper",
  "version": "1.0",
  "description": "Scrape LinkedIn profile data to Google Sheets with Quick Add or Full Scrape",
  "permissions": ["activeTab", "scripting", "identity", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.googleapis.com/*",
    "https://docs.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ],
  "oauth2": {
    "client_id": "729580817442-sog4pba5qj3vn64r2g3e6p4a75ctb2ku.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
